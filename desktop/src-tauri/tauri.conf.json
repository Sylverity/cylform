{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Cylform",
  "version": "0.7.2",
  "identifier": "com.sylverity.cylform",
  "build": {
    "beforeDevCommand": "cd ../src-ui && pnpm run dev -- --host 127.0.0.1 --port 5173",
    "beforeBuildCommand": "cd ../src-ui && pnpm run build",
    "frontendDist": "../../desktop/src-ui/dist"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: asset: http://asset.localhost; connect-src ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
