{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CYLview-NG",
  "version": "0.1.2",
  "identifier": "com.cylview.ng",
  "build": {
    "beforeDevCommand": "cd ../src-ui && npm run dev -- --host 127.0.0.1 --port 5173",
    "beforeBuildCommand": "cd ../src-ui && npm run build",
    "frontendDist": "../../desktop/src-ui/dist"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  }
}
